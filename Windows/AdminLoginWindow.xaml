<Window x:Class="BankManagementSystem.Windows.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Login"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="{StaticResource WelcomeGradient}">

    <Window.Resources>
        <Storyboard x:Key="CardEntranceAnimation">
            <DoubleAnimation Storyboard.TargetName="LoginCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LoginCard"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                             From="30" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LoginCard"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                             From="0.95" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LoginCard"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                             From="0.95" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="Admin Login"
                           Foreground="#9CA3AF"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarButton}" Click="Minimize_Click" Content="&#x2014;"/>
                    <Button Style="{StaticResource CloseButton}" Click="Close_Click" Content="&#x2715;"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Border x:Name="LoginCard"
                    Background="White"
                    CornerRadius="16"
                    Width="420"
                    Padding="40"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5"
                    Effect="{StaticResource CardShadow}">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                        <TranslateTransform Y="30"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Clip>
                    <RectangleGeometry RadiusX="16" RadiusY="16">
                        <RectangleGeometry.Rect>
                            <Rect X="0" Y="0" Width="420" Height="500"/>
                        </RectangleGeometry.Rect>
                    </RectangleGeometry>
                </Border.Clip>

                <StackPanel>
                    <!-- Admin Icon -->
                    <Border Width="64" Height="64"
                            CornerRadius="16"
                            Background="#FEF3C7"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <TextBlock Text="&#x1F464;" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Admin Portal"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"
                               TextAlignment="Center"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Sign in to manage the banking system"
                               FontSize="13"
                               Foreground="#6B7280"
                               TextAlignment="Center"
                               Margin="0,0,0,32"/>

                    <!-- Email -->
                    <TextBlock Text="Email Address" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="EmailBox"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,16"/>

                    <!-- Password -->
                    <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,8"/>

                    <!-- Error -->
                    <TextBlock x:Name="ErrorText"
                               Foreground="#EF4444"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"
                               Visibility="Collapsed"/>

                    <!-- Login Button -->
                    <Button Style="{StaticResource AmberButton}"
                            Content="Sign In"
                            Click="Login_Click"
                            Height="48"
                            FontSize="16"
                            Margin="0,0,0,16"/>

                    <!-- Hint -->
                    <TextBlock Text="Default: admin@bms.com / admin12345"
                               FontSize="11"
                               Foreground="#9CA3AF"
                               TextAlignment="Center"
                               Margin="0,0,0,16"/>

                    <!-- Back -->
                    <Button Style="{StaticResource LinkButton}"
                            Content="Back to Welcome"
                            Click="Back_Click"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
