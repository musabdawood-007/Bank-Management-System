<Window x:Class="BankManagementSystem.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bank Management System"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="{StaticResource WelcomeGradient}">

    <Window.Resources>
        <!-- Floating animation for bank icon -->
        <Storyboard x:Key="FloatAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BankIcon"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                             From="0" To="-8" Duration="0:0:2" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Shimmer glow on title text -->
        <Storyboard x:Key="TitleShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="TitleGlowBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.6" Duration="0:0:2" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Staggered entrance: Icon -->
        <Storyboard x:Key="IconEntrance">
            <DoubleAnimation Storyboard.TargetName="BankIcon"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BankIcon"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                             From="0.5" To="1" Duration="0:0:0.5" BeginTime="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BankIcon"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                             From="0.5" To="1" Duration="0:0:0.5" BeginTime="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Staggered entrance: Title -->
        <Storyboard x:Key="TitleEntrance">
            <DoubleAnimation Storyboard.TargetName="TitlePanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitlePanel"
                             Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                             From="15" To="0" Duration="0:0:0.5" BeginTime="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Staggered entrance: Subtitle -->
        <Storyboard x:Key="SubtitleEntrance">
            <DoubleAnimation Storyboard.TargetName="SubtitleText"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SubtitleText"
                             Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                             From="10" To="0" Duration="0:0:0.4" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Staggered entrance: Buttons -->
        <Storyboard x:Key="ButtonsEntrance">
            <DoubleAnimation Storyboard.TargetName="ButtonsPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ButtonsPanel"
                             Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                             From="20" To="0" Duration="0:0:0.5" BeginTime="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Staggered entrance: Register link -->
        <Storyboard x:Key="RegisterEntrance">
            <DoubleAnimation Storyboard.TargetName="RegisterPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.9">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RegisterPanel"
                             Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                             From="10" To="0" Duration="0:0:0.4" BeginTime="0:0:0.9">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="Bank Management System"
                           Foreground="#9CA3AF"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarButton}" Click="Minimize_Click" Content="&#x2014;"/>
                    <Button Style="{StaticResource CloseButton}" Click="Close_Click" Content="&#x2715;"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="480">

                <!-- Bank Icon with floating animation -->
                <Border x:Name="BankIcon"
                        Width="80" Height="80"
                        CornerRadius="20"
                        Background="#7C3AED"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,24"
                        Opacity="0"
                        Effect="{StaticResource GlowEffect}"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                            <TranslateTransform Y="0"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <TextBlock Text="&#x1F3E6;" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title with shimmer glow -->
                <Grid HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border x:Name="TitleGlowBorder"
                            Background="#7C3AED"
                            CornerRadius="8"
                            Opacity="0"
                            Margin="-8,-4,-8,-4"/>
                    <StackPanel x:Name="TitlePanel"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="15"/>
                        </StackPanel.RenderTransform>
                        <TextBlock Text="BANK MANAGEMENT"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   LetterSpacing="4"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="SYSTEM"
                                   Foreground="#7C3AED"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   LetterSpacing="8"/>
                    </StackPanel>
                </Grid>

                <!-- Subtitle -->
                <TextBlock x:Name="SubtitleText"
                           Text="Secure. Reliable. Modern Banking Solutions."
                           Foreground="#9CA3AF"
                           FontSize="14"
                           TextAlignment="Center"
                           Margin="0,0,0,48"
                           Opacity="0"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TranslateTransform Y="10"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- Buttons -->
                <StackPanel x:Name="ButtonsPanel"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="20"/>
                    </StackPanel.RenderTransform>
                    <!-- Customer Login Button -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Customer Login"
                            Click="CustomerLogin_Click"
                            Margin="0,0,0,12"
                            Height="50"
                            FontSize="16"/>

                    <!-- Admin Login Button -->
                    <Button Style="{StaticResource AmberButton}"
                            Content="Admin Login"
                            Click="AdminLogin_Click"
                            Margin="0,0,0,24"
                            Height="50"
                            FontSize="16"/>
                </StackPanel>

                <!-- Register Link -->
                <StackPanel x:Name="RegisterPanel"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="10"/>
                    </StackPanel.RenderTransform>
                    <TextBlock TextAlignment="Center" Margin="0,8,0,0">
                        <Run Text="Don't have an account? " Foreground="#9CA3AF" FontSize="14"/>
                    </TextBlock>
                    <Button Style="{StaticResource LinkButton}"
                            Content="Register Now"
                            Click="Register_Click"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
