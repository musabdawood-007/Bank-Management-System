<Window x:Class="BankManagementSystem.Windows.CustomerRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Registration"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="#F3F4F6">

    <Window.Resources>
        <Storyboard x:Key="EntranceAnimation">
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                             From="20" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                             From="0.98" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                             From="0.98" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="White" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="Customer Registration"
                           Foreground="#374151"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource LightTitleBarButton}" Click="Minimize_Click" Content="&#x2014;"/>
                    <Button Style="{StaticResource LightCloseButton}" Click="Close_Click" Content="&#x2715;"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40,20,40,40">
            <StackPanel x:Name="ContentPanel"
                        MaxWidth="700"
                        HorizontalAlignment="Center"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                        <TranslateTransform Y="20"/>
                    </TransformGroup>
                </StackPanel.RenderTransform>

                <!-- Header -->
                <TextBlock Text="Open Your Account"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Fill in your details to create a new bank account"
                           FontSize="14"
                           Foreground="#6B7280"
                           Margin="0,0,0,24"/>

                <!-- Personal Information -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Personal Information"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#7C3AED"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Full Name -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Full Name *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="FullNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- Email -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Email *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="EmailBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- Phone -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="Phone *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="PhoneBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- CNIC -->
                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="CNIC *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="CnicBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                                         MaxLength="13"/>
                            </StackPanel>

                            <!-- DOB -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Date of Birth *" Style="{StaticResource FieldLabel}"/>
                                <DatePicker x:Name="DobPicker" Height="42" FontSize="14" Margin="0,0,0,0"
                                            SelectedDateFormat="Short"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Address -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Address"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#7C3AED"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- City -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="City *" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CityCombo" Style="{StaticResource ModernComboBox}"
                                          SelectionChanged="CityCombo_SelectionChanged" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- Area -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Area *" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="AreaCombo" Style="{StaticResource ModernComboBox}"
                                          IsEnabled="False" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Account Setup -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Account Setup"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#7C3AED"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Account Type -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Account Type *" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="AccountTypeCombo" Style="{StaticResource ModernComboBox}"
                                          Margin="0,0,0,12">
                                    <ComboBoxItem Content="Savings"/>
                                    <ComboBoxItem Content="Current"/>
                                    <ComboBoxItem Content="Business"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Placeholder -->
                            <StackPanel Grid.Row="0" Grid.Column="2"/>

                            <!-- PIN -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="PIN (4 digits) *" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="PinBox" Style="{StaticResource ModernPasswordBox}"
                                             MaxLength="4" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- Confirm PIN -->
                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="Confirm PIN *" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="ConfirmPinBox" Style="{StaticResource ModernPasswordBox}"
                                             MaxLength="4" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <TextBlock x:Name="ErrorText"
                           Foreground="#EF4444"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Visibility="Collapsed"/>

                <!-- Success -->
                <Border x:Name="SuccessPanel"
                        Background="#F0FDF4"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Account Created Successfully!"
                                   Foreground="#16A34A"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="AccountNumberText"
                                   Foreground="#15803D"
                                   FontSize="16"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,40">
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Register"
                            Click="Register_Click"
                            Width="160"
                            Margin="0,0,12,0"/>
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Clear"
                            Click="Clear_Click"
                            Width="120"
                            Margin="0,0,12,0"/>
                    <Button Style="{StaticResource OutlineButton}"
                            Content="Cancel"
                            Click="Cancel_Click"
                            Width="120"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
