<Window x:Class="BankManagementSystem.Windows.AdminShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bank Management System - Admin"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="#F3F4F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource SidebarGradient}" CornerRadius="0"
                Opacity="0"
                RenderTransformOrigin="0,0.5">
            <Border.RenderTransform>
                <TranslateTransform X="-240"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Row="0" Margin="20,24,20,32">
                    <TextBlock Text="BMS" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,2"/>
                    <TextBlock Text="Admin Panel" FontSize="12" Foreground="#9CA3AF"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="0,0,0,0">
                    <RadioButton x:Name="NavDashboard" Style="{StaticResource SidebarButton}"
                                 Content="Dashboard" GroupName="AdminNav" IsChecked="True"
                                 Checked="Nav_Checked" Tag="Dashboard"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="Customers" GroupName="AdminNav"
                                 Checked="Nav_Checked" Tag="Customers"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="Transactions" GroupName="AdminNav"
                                 Checked="Nav_Checked" Tag="Transactions"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="Loans" GroupName="AdminNav"
                                 Checked="Nav_Checked" Tag="Loans"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="Fraud Alerts" GroupName="AdminNav"
                                 Checked="Nav_Checked" Tag="Fraud"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="Audit Log" GroupName="AdminNav"
                                 Checked="Nav_Checked" Tag="Audit"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="Analytics" GroupName="AdminNav"
                                 Checked="Nav_Checked" Tag="Analytics"/>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="20,0,20,24">
                    <Border BorderBrush="#312E81" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#7C3AED" Margin="0,0,10,0">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="AdminNameText" Foreground="White" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Administrator" Foreground="#9CA3AF" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Style="{StaticResource LinkButton}" Content="Logout"
                            Click="Logout_Click" Foreground="#9CA3AF" Margin="0,8,0,0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="White" MouseLeftButtonDown="TitleBar_MouseDown"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Bank Management System"
                               Foreground="#6B7280" FontSize="12"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource LightTitleBarButton}" Click="Minimize_Click" Content="&#x2014;"/>
                        <Button Style="{StaticResource LightCloseButton}" Click="Close_Click" Content="&#x2715;"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Header Bar -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <TextBlock x:Name="PageTitle" Text="Dashboard"
                               FontSize="20" FontWeight="Bold" Foreground="#111827"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Page Frame -->
            <Frame x:Name="ContentFrame" Grid.Row="2" NavigationUIVisibility="Hidden"
                   Margin="24,16,24,16"
                   Opacity="0" Navigated="ContentFrame_Navigated"/>
        </Grid>
    </Grid>
</Window>
