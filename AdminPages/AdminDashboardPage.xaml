<Page x:Class="BankManagementSystem.AdminPages.AdminDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Admin Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,16">
        <StackPanel x:Name="PageRoot" Opacity="0" RenderTransformOrigin="0.5,0">
            <StackPanel.RenderTransform>
                <TranslateTransform Y="20"/>
            </StackPanel.RenderTransform>
            <!-- Stat Cards Row -->
            <UniformGrid Columns="5" Margin="0,0,0,20">
                <!-- Total Customers -->
                <Border x:Name="StatCard1" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatBlueGradient}" Margin="0,0,8,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Total Customers" Foreground="#BFDBFE" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TotalCustomersText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Total Deposits -->
                <Border x:Name="StatCard2" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatGreenGradient}" Margin="8,0,8,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Total Deposits" Foreground="#BBF7D0" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TotalDepositsText" Text="PKR 0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Pending Loans -->
                <Border x:Name="StatCard3" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatAmberGradient}" Margin="8,0,8,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Pending Loans" Foreground="#FEF3C7" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="PendingLoansText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Fraud Alerts -->
                <Border x:Name="StatCard4" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatRedGradient}" Margin="8,0,8,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Fraud Alerts" Foreground="#FECACA" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="FraudAlertsText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Total Transactions -->
                <Border x:Name="StatCard5" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatPurpleGradient}" Margin="8,0,0,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Total Transactions" Foreground="#DDD6FE" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TotalTransactionsText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Activity -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Recent Activity" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                    <DataGrid x:Name="RecentGrid" Style="{StaticResource ModernDataGrid}" MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Transaction ID" Binding="{Binding TransactionId}" Width="100"/>
                            <DataGridTextColumn Header="Account" Binding="{Binding AccountNumber}" Width="150"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="100"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='PKR {0:N2}'}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
