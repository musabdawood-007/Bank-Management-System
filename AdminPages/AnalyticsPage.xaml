<Page x:Class="BankManagementSystem.AdminPages.AnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Analytics">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,16">
        <StackPanel x:Name="PageRoot" Opacity="0" RenderTransformOrigin="0.5,0">
            <StackPanel.RenderTransform>
                <TranslateTransform Y="20"/>
            </StackPanel.RenderTransform>
            <!-- Row 1: 4 stat cards -->
            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatPurpleGradient}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Total Balance" Foreground="#DDD6FE" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TotalBalanceText" Text="PKR 0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatGreenGradient}" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Total Deposits" Foreground="#BBF7D0" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TotalDepositsText" Text="PKR 0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatRedGradient}" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Total Withdrawals" Foreground="#FECACA" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TotalWithdrawalsText" Text="PKR 0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatAmberGradient}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Loans Disbursed" Foreground="#FEF3C7" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="LoansDisbursedText" Text="PKR 0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 2: 3 stat cards -->
            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatBlueGradient}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Active Loans" Foreground="#BFDBFE" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ActiveLoansText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatGreenGradient}" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Active Accounts" Foreground="#BBF7D0" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ActiveAccountsText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatPurpleGradient}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Total Transactions" Foreground="#DDD6FE" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TotalTransactionsText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Summary -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="System Summary" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,12"/>
                    <TextBlock x:Name="SummaryText" Foreground="#374151" FontSize="14" TextWrapping="Wrap" LineHeight="24"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
