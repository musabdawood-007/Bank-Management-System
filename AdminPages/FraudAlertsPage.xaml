<Page x:Class="BankManagementSystem.AdminPages.FraudAlertsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Fraud Alerts">

    <Grid x:Name="PageRoot" Opacity="0" RenderTransformOrigin="0.5,0">
        <Grid.RenderTransform>
            <TranslateTransform Y="20"/>
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- DataGrid -->
        <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="0,0,8,0">
            <StackPanel>
                <TextBlock Text="Fraud Alerts" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                <DataGrid x:Name="FraudGrid" Style="{StaticResource ModernDataGrid}"
                          SelectionChanged="FraudGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding AlertId}" Width="50"/>
                        <DataGridTextColumn Header="Account" Binding="{Binding AccountNumber}" Width="140"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="140"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding AlertType}" Width="120"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="Created" Binding="{Binding CreatedDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Resolve Panel -->
        <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="8,0,0,0"
                x:Name="ResolvePanel" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Resolve Alert" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>

                <TextBlock Text="Alert Type" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="DetailType" Foreground="#111827" FontSize="14" Margin="0,0,0,12"/>

                <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="DetailDescription" Foreground="#111827" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <TextBlock Text="Resolution Notes" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ResolveNotesBox" Style="{StaticResource ModernTextBox}"
                         Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"
                         Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource GreenButton}" Content="Resolve"
                            Click="Resolve_Click" Width="120" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Cancel"
                            Click="Cancel_Click" Width="100"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
