<Page x:Class="BankManagementSystem.AdminPages.LoanManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Loan Management">

    <Grid x:Name="PageRoot" Opacity="0" RenderTransformOrigin="0.5,0">
        <Grid.RenderTransform>
            <TranslateTransform Y="20"/>
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Stat Cards -->
        <UniformGrid Columns="3" Grid.Row="0" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatAmberGradient}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Pending" Foreground="#FEF3C7" FontSize="12" FontWeight="Medium"/>
                    <TextBlock x:Name="PendingText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatGreenGradient}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Approved" Foreground="#BBF7D0" FontSize="12" FontWeight="Medium"/>
                    <TextBlock x:Name="ApprovedText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource StatRedGradient}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Rejected" Foreground="#FECACA" FontSize="12" FontWeight="Medium"/>
                    <TextBlock x:Name="RejectedText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Loans DataGrid -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="0,0,8,0">
                <DataGrid x:Name="LoansGrid" Style="{StaticResource ModernDataGrid}"
                          SelectionChanged="LoansGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding LoanAppId}" Width="50"/>
                        <DataGridTextColumn Header="Account" Binding="{Binding AccountNumber}" Width="140"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="140"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding LoanAmount, StringFormat='PKR {0:N0}'}" Width="110"/>
                        <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="120"/>
                        <DataGridTextColumn Header="Tenure" Binding="{Binding TenureMonths}" Width="60"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="Applied" Binding="{Binding ApplicationDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Detail Panel -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="8,0,0,0"
                    x:Name="DetailPanel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Loan Details" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,12"/>

                        <TextBlock Text="Customer" Style="{StaticResource FieldLabel}"/>
                        <TextBlock x:Name="DetailCustomer" Foreground="#111827" FontSize="14" Margin="0,0,0,12"/>

                        <TextBlock Text="Requested Amount" Style="{StaticResource FieldLabel}"/>
                        <TextBlock x:Name="DetailAmount" Foreground="#111827" FontSize="14" Margin="0,0,0,12"/>

                        <TextBlock Text="Purpose" Style="{StaticResource FieldLabel}"/>
                        <TextBlock x:Name="DetailPurpose" Foreground="#111827" FontSize="14" Margin="0,0,0,12"/>

                        <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
                        <TextBlock x:Name="DetailStatus" Foreground="#111827" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,20"/>

                        <!-- Approve Section -->
                        <Border x:Name="ApproveSection" Background="#F0FDF4" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Approve Loan" FontWeight="SemiBold" Foreground="#16A34A" Margin="0,0,0,12"/>

                                <TextBlock Text="Approved Amount (PKR)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="ApprovedAmountBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                                <TextBlock Text="Interest Rate (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="InterestRateBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                                <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="ApproveNotesBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>

                                <Button Style="{StaticResource GreenButton}" Content="Approve"
                                        Click="Approve_Click" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Reject Section -->
                        <Border x:Name="RejectSection" Background="#FEF2F2" CornerRadius="8" Padding="16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Reject Loan" FontWeight="SemiBold" Foreground="#DC2626" Margin="0,0,0,12"/>

                                <TextBlock Text="Rejection Notes" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="RejectNotesBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>

                                <Button Style="{StaticResource RedButton}" Content="Reject"
                                        Click="Reject_Click" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
