<Page x:Class="BankManagementSystem.AdminPages.AllTransactionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="All Transactions">

    <Border x:Name="PageRoot" Style="{StaticResource CardStyle}" Opacity="0" RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <TranslateTransform Y="20"/>
        </Border.RenderTransform>
        <StackPanel>
            <TextBlock Text="All Transactions" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
            <DataGrid x:Name="TransactionsGrid" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding TransactionId}" Width="60"/>
                    <DataGridTextColumn Header="Account" Binding="{Binding AccountNumber}" Width="150"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="150"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="100"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='PKR {0:N2}'}" Width="120"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                    <DataGridTextColumn Header="Reference" Binding="{Binding ReferenceNumber}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Border>
</Page>
