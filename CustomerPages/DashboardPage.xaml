<Page x:Class="BankManagementSystem.CustomerPages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Customer Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,16">
        <StackPanel x:Name="PageRoot" Opacity="0" RenderTransformOrigin="0.5,0">
            <StackPanel.RenderTransform>
                <TranslateTransform Y="20"/>
            </StackPanel.RenderTransform>
            <!-- Stat Cards Row -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border x:Name="StatCard1" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatPurpleGradient}" Margin="0,0,8,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Balance" Foreground="#DDD6FE" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="BalanceText" Text="PKR 0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border x:Name="StatCard2" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatBlueGradient}" Margin="8,0,8,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Account Type" Foreground="#BFDBFE" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="AccountTypeText" Text="--" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border x:Name="StatCard3" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatGreenGradient}" Margin="8,0,8,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Status" Foreground="#BBF7D0" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="StatusText" Text="--" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border x:Name="StatCard4" Style="{StaticResource StatCardStyle}" Background="{StaticResource StatAmberGradient}" Margin="8,0,0,0"
                        Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Transactions" Foreground="#FEF3C7" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TransactionCountText" Text="0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Transactions -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Recent Transactions" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                    <DataGrid x:Name="TransactionsGrid" Style="{StaticResource ModernDataGrid}" MaxHeight="250">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="100"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='PKR {0:N2}'}" Width="120"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- My Loans -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="My Loans" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                    <DataGrid x:Name="LoansGrid" Style="{StaticResource ModernDataGrid}" MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Amount" Binding="{Binding LoanAmount, StringFormat='PKR {0:N0}'}" Width="120"/>
                            <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="150"/>
                            <DataGridTextColumn Header="Tenure" Binding="{Binding TenureMonths}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            <DataGridTextColumn Header="Approved" Binding="{Binding ApprovedAmount, StringFormat='PKR {0:N0}'}" Width="120"/>
                            <DataGridTextColumn Header="Rate" Binding="{Binding InterestRate}" Width="80"/>
                            <DataGridTextColumn Header="Applied" Binding="{Binding ApplicationDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
