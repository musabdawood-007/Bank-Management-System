<Page x:Class="BankManagementSystem.CustomerPages.LoanRequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Loan Request">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,16">
        <StackPanel x:Name="PageRoot" MaxWidth="700" HorizontalAlignment="Left"
                    Opacity="0" RenderTransformOrigin="0.5,0">
            <StackPanel.RenderTransform>
                <TranslateTransform Y="20"/>
            </StackPanel.RenderTransform>
            <!-- Form -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Apply for a Loan" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Loan Type" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="LoanTypeCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16">
                                <ComboBoxItem Content="Personal Loan"/>
                                <ComboBoxItem Content="Business Loan"/>
                                <ComboBoxItem Content="Home Loan"/>
                                <ComboBoxItem Content="Car Loan"/>
                                <ComboBoxItem Content="Education Loan"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Loan Amount (PKR)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="LoanAmountBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Tenure (Months)" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="TenureCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,8">
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="24"/>
                        <ComboBoxItem Content="36"/>
                        <ComboBoxItem Content="48"/>
                        <ComboBoxItem Content="60"/>
                    </ComboBox>

                    <!-- Message -->
                    <TextBlock x:Name="MessageText" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,16" Visibility="Collapsed"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}" Content="Submit Application"
                                Click="Submit_Click" Width="200" Margin="0,0,12,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Clear"
                                Click="Clear_Click" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- My Loans -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="My Loan Applications" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                    <DataGrid x:Name="LoansGrid" Style="{StaticResource ModernDataGrid}" MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Amount" Binding="{Binding LoanAmount, StringFormat='PKR {0:N0}'}" Width="120"/>
                            <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="130"/>
                            <DataGridTextColumn Header="Tenure" Binding="{Binding TenureMonths}" Width="70"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="Approved" Binding="{Binding ApprovedAmount, StringFormat='PKR {0:N0}'}" Width="120"/>
                            <DataGridTextColumn Header="Rate (%)" Binding="{Binding InterestRate}" Width="70"/>
                            <DataGridTextColumn Header="Applied" Binding="{Binding ApplicationDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
